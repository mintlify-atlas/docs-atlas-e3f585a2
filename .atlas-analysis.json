  "keyFeatures": [
    "Infrastructure as Code with declarative configuration syntax",
    "Execution planning with preview of infrastructure changes",
    "Resource graph for parallel creation and dependency management",
    "State management with remote backends and locking",
    "Provider plugin system supporting 3000+ integrations",
    "Module system for reusable infrastructure components",
    "Workspace support for managing multiple environments",
    "Built-in testing framework for infrastructure validation",
    "Stacks orchestration for complex deployments",
    "HCL (HashiCorp Configuration Language) with expressions and functions"
  ],
  "publicApiSurface": [
    "terraform init - Initialize working directory and download providers",
    "terraform plan - Generate and preview execution plan",
    "terraform apply - Create or update infrastructure",
    "terraform destroy - Destroy managed infrastructure",
    "terraform validate - Validate configuration files",
    "terraform fmt - Format configuration files",
    "terraform show - Show current state or plan",
    "terraform output - Extract output values from state",
    "terraform state - Advanced state management operations",
    "terraform import - Import existing infrastructure into state",
    "terraform workspace - Manage workspaces for multiple environments",
    "terraform providers - Manage provider plugins",
    "terraform console - Interactive console for expressions",
    "terraform graph - Generate visual dependency graph",
    "terraform taint/untaint - Mark resources for recreation",
    "terraform test - Run infrastructure tests",
    "terraform get - Download and update modules",
    "terraform refresh - Update state with real infrastructure",
    "terraform login/logout - Manage Terraform Cloud credentials",
    "terraform force-unlock - Release stuck state locks"
  ]
}
